{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svc-platform.local/schemas/vehicle-profile-v1.schema.json",
  "title": "SVC Mobile vehicle performance profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "manufacturer",
    "model",
    "generation",
    "yearFrom",
    "yearTo",
    "engineName",
    "engineDisplacementCc",
    "maximumTorqueNm",
    "nominalPowerKw",
    "gearboxGears",
    "fuelCapacityLiters",
    "fuelReserveLiters",
    "iceWarningTemperatureCelsius",
    "idleRpm",
    "idleToleranceRpm",
    "torquePeakRpm",
    "powerPeakRpm",
    "tachometerScaleMinRpm",
    "tachometerScaleMaxRpm",
    "warningStartRpm",
    "redZoneStartRpm",
    "revLimiterRpm",
    "source",
    "reference",
    "confidence"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "manufacturer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "generation": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 64
    },
    "yearFrom": { "$ref": "#/$defs/nullableYear" },
    "yearTo": { "$ref": "#/$defs/nullableYear" },
    "engineName": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 96
    },
    "engineDisplacementCc": { "$ref": "#/$defs/nullablePositiveNumber" },
    "maximumTorqueNm": { "$ref": "#/$defs/nullablePositiveNumber" },
    "nominalPowerKw": { "$ref": "#/$defs/nullablePositiveNumber" },
    "gearboxGears": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 12
    },
    "fuelCapacityLiters": { "$ref": "#/$defs/nullablePositiveNumber" },
    "fuelReserveLiters": { "$ref": "#/$defs/nullableNonNegativeNumber" },
    "iceWarningTemperatureCelsius": {
      "type": ["number", "null"],
      "minimum": -60,
      "maximum": 30
    },
    "idleRpm": { "$ref": "#/$defs/nullableRpm" },
    "idleToleranceRpm": { "$ref": "#/$defs/nullableRpm" },
    "torquePeakRpm": { "$ref": "#/$defs/nullableRpm" },
    "powerPeakRpm": { "$ref": "#/$defs/nullableRpm" },
    "tachometerScaleMinRpm": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30000
    },
    "tachometerScaleMaxRpm": { "$ref": "#/$defs/nullableRpm" },
    "warningStartRpm": { "$ref": "#/$defs/nullableRpm" },
    "redZoneStartRpm": { "$ref": "#/$defs/nullableRpm" },
    "revLimiterRpm": { "$ref": "#/$defs/nullableRpm" },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "reference": {
      "type": "string",
      "pattern": "^docs/[A-Za-z0-9._/-]+\\.md$"
    },
    "confidence": {
      "enum": [
        "verified",
        "product-owner-approved",
        "estimated",
        "unknown"
      ]
    }
  },
  "$defs": {
    "nullableYear": {
      "type": ["integer", "null"],
      "minimum": 1886,
      "maximum": 2200
    },
    "nullableRpm": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 30000
    },
    "nullablePositiveNumber": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0
    },
    "nullableNonNegativeNumber": {
      "type": ["number", "null"],
      "minimum": 0
    }
  }
}
