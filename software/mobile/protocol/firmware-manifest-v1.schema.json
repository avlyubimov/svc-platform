{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svc-platform.example/schema/firmware-manifest-v1.schema.json",
  "title": "SVC firmware release manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseVersion",
    "channel",
    "minimumMobileVersion",
    "components"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "releaseVersion": { "$ref": "#/$defs/version" },
    "channel": { "enum": ["dev", "beta", "stable"] },
    "minimumMobileVersion": { "$ref": "#/$defs/version" },
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "version",
        "hardware",
        "protocolVersion",
        "file",
        "size",
        "sha256",
        "signature",
        "minimumBootloader"
      ],
      "properties": {
        "target": { "enum": ["stm32-main", "e73-radio"] },
        "version": { "$ref": "#/$defs/version" },
        "hardware": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9][A-Z0-9._-]{0,31}$"
          }
        },
        "protocolVersion": {
          "type": "integer",
          "minimum": 1
        },
        "file": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^(placeholder|[0-9a-f]{64})$"
        },
        "signature": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "minimumBootloader": { "$ref": "#/$defs/version" }
      }
    }
  }
}
