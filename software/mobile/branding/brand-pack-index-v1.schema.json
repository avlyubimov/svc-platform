{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svc-platform.local/schemas/brand-pack-index-v1.schema.json",
  "title": "SVC Mobile BrandPack index v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "defaultProfileId",
    "fallbackProfileId",
    "profiles"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "defaultProfileId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "fallbackProfileId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "configuration"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
          },
          "configuration": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}\\.json$"
          }
        }
      }
    }
  }
}
