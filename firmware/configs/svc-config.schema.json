{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svc-platform.local/schemas/svc-config.schema.json",
  "title": "SVC Device Configuration",
  "type": "object",
  "required": [
    "device",
    "battery",
    "thermal",
    "power_budget",
    "telemetry",
    "outputs",
    "manual_controls",
    "operating_modes",
    "external_capabilities"
  ],
  "additionalProperties": false,
  "properties": {
    "device": {
      "type": "object",
      "required": [
        "name",
        "vehicle_profile",
        "hardware"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "vehicle_profile": {
          "type": "string",
          "minLength": 1
        },
        "hardware": {
          "type": "object",
          "required": [
            "power_board",
            "logic_board",
            "front_board"
          ],
          "additionalProperties": false,
          "properties": {
            "power_board": {
              "type": "string",
              "minLength": 1
            },
            "logic_board": {
              "type": "string",
              "minLength": 1
            },
            "front_board": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "battery": {
      "type": "object",
      "required": [
        "warn_v",
        "cutoff_v",
        "recovery_v",
        "shutdown_delay_s"
      ],
      "additionalProperties": false,
      "properties": {
        "warn_v": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cutoff_v": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "recovery_v": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "shutdown_delay_s": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "thermal": {
      "type": "object",
      "required": [
        "pcb",
        "power_zone_a",
        "power_zone_b"
      ],
      "additionalProperties": false,
      "properties": {
        "pcb": {
          "$ref": "#/$defs/thermalZone"
        },
        "power_zone_a": {
          "$ref": "#/$defs/thermalZone"
        },
        "power_zone_b": {
          "$ref": "#/$defs/thermalZone"
        }
      }
    },
    "power_budget": {
      "type": "object",
      "required": [
        "total_current_limit_a",
        "shed_priority_order"
      ],
      "additionalProperties": false,
      "properties": {
        "total_current_limit_a": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "shed_priority_order": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/loadPriority"
          }
        }
      }
    },
    "telemetry": {
      "type": "object",
      "required": [
        "total_current",
        "output_current",
        "thermal"
      ],
      "additionalProperties": false,
      "properties": {
        "total_current": {
          "$ref": "#/$defs/totalCurrentTelemetry"
        },
        "output_current": {
          "type": "array",
          "minItems": 10,
          "maxItems": 10,
          "items": {
            "$ref": "#/$defs/outputCurrentTelemetry"
          }
        },
        "thermal": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/thermalTelemetry"
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "manual_controls": {
      "type": "object",
      "required": ["fog"],
      "additionalProperties": false,
      "properties": {
        "fog": {
          "type": "object",
          "required": ["pair_a", "pair_b", "restore_on_boot", "output_manager_authority"],
          "additionalProperties": false,
          "properties": {
            "pair_a": {"$ref": "#/$defs/fogManualInputA"},
            "pair_b": {"$ref": "#/$defs/fogManualInputB"},
            "restore_on_boot": {"const": false},
            "output_manager_authority": {"const": true}
          }
        }
      }
    },
    "operating_modes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "allowed_roles"],
        "additionalProperties": false,
        "properties": {
          "id": {"enum": ["DAY", "NIGHT", "SERVICE_COMPRESSOR", "C36_RESCUE_CHARGE", "ENGINE_OFF"]},
          "allowed_roles": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/outputRole"}}
        }
      }
    },
    "external_capabilities": {
      "type": "object",
      "required": ["C36_BIDIRECTIONAL"],
      "additionalProperties": false,
      "properties": {
        "C36_BIDIRECTIONAL": {
          "type": "object",
          "required": ["managed_output", "counted_in_pb_current", "requires_mcu", "direct_battery_branch", "dedicated_near_battery_fuse", "starter_current_source"],
          "additionalProperties": false,
          "properties": {
            "managed_output": {"const": false},
            "counted_in_pb_current": {"const": false},
            "requires_mcu": {"const": false},
            "direct_battery_branch": {"const": true},
            "dedicated_near_battery_fuse": {"const": true},
            "starter_current_source": {"const": false}
          }
        }
      }
    },
    "fog_logic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "day_lux": {
          "type": "integer",
          "minimum": 0
        },
        "dusk_lux": {
          "type": "integer",
          "minimum": 0
        },
        "night_lux": {
          "type": "integer",
          "minimum": 0
        },
        "day_pwm": {
          "$ref": "#/$defs/pwmPercent"
        },
        "dusk_pwm": {
          "$ref": "#/$defs/pwmPercent"
        },
        "night_pwm": {
          "$ref": "#/$defs/pwmPercent"
        },
        "high_beam_pwm": {
          "$ref": "#/$defs/pwmPercent"
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "loadPriority": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C"
      ]
    },
    "outputId": {
      "type": "string",
      "enum": [
        "OUT1",
        "OUT2",
        "OUT3",
        "OUT4",
        "OUT5",
        "OUT6",
        "OUT7",
        "OUT8",
        "OUT9",
        "OUT10"
      ]
    },
    "outputRole": {
      "type": "string",
      "enum": [
        "NONE",
        "USB",
        "CIGARETTE_SOCKET",
        "FOG_LEFT",
        "FOG_RIGHT",
        "CHIGEE",
        "HEATED_SEAT_RIDER",
        "HEATED_SEAT_PASSENGER",
        "DVR",
        "AUX_BRAKE",
        "SPARE",
        "CIGARETTE_COMPRESSOR",
        "HIGH_CURRENT_RESERVE",
        "FOG_PRIMARY_LEFT",
        "FOG_PRIMARY_RIGHT",
        "LOW_CURRENT_RESERVE_1",
        "FOG_SECONDARY_LEFT",
        "FOG_SECONDARY_RIGHT",
        "LOW_CURRENT_RESERVE_2",
        "LOW_CURRENT_RESERVE_3",
        "MEDIUM_CURRENT_RESERVE"
      ]
    },
    "fogManualInputA": {
      "type": "object",
      "required": ["input_signal", "return_signal", "behavior", "active_low", "debounce_ms", "stuck_timeout_ms", "channel_delay_ms", "roles"],
      "additionalProperties": false,
      "properties": {
        "input_signal": {"const": "FOG_A_SW_IN"},
        "return_signal": {"const": "SW_COMMON"},
        "behavior": {"enum": ["momentary_toggle", "maintained"]},
        "active_low": {"const": true},
        "debounce_ms": {"type": "integer", "minimum": 1},
        "stuck_timeout_ms": {"type": "integer", "minimum": 1000},
        "channel_delay_ms": {"type": "integer", "minimum": 1},
        "roles": {
          "type": "array",
          "prefixItems": [{"const": "FOG_PRIMARY_LEFT"}, {"const": "FOG_PRIMARY_RIGHT"}],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "fogManualInputB": {
      "type": "object",
      "required": ["input_signal", "return_signal", "behavior", "active_low", "debounce_ms", "stuck_timeout_ms", "channel_delay_ms", "roles"],
      "additionalProperties": false,
      "properties": {
        "input_signal": {"const": "FOG_B_SW_IN"},
        "return_signal": {"const": "SW_COMMON"},
        "behavior": {"enum": ["momentary_toggle", "maintained"]},
        "active_low": {"const": true},
        "debounce_ms": {"type": "integer", "minimum": 1},
        "stuck_timeout_ms": {"type": "integer", "minimum": 1000},
        "channel_delay_ms": {"type": "integer", "minimum": 1},
        "roles": {
          "type": "array",
          "prefixItems": [{"const": "FOG_SECONDARY_LEFT"}, {"const": "FOG_SECONDARY_RIGHT"}],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "id",
        "role",
        "fuse_a",
        "current_limit_a",
        "pwm",
        "priority"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/outputId"
        },
        "role": {
          "$ref": "#/$defs/outputRole"
        },
        "fuse_a": {
          "type": "integer",
          "minimum": 1
        },
        "current_limit_a": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "pwm": {
          "type": "boolean"
        },
        "priority": {
          "$ref": "#/$defs/loadPriority"
        }
      }
    },
    "pwmPercent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "thermalZone": {
      "type": "object",
      "required": [
        "warn_c",
        "cutoff_c",
        "recovery_c"
      ],
      "additionalProperties": false,
      "properties": {
        "warn_c": {
          "type": "integer"
        },
        "cutoff_c": {
          "type": "integer"
        },
        "recovery_c": {
          "type": "integer"
        }
      }
    },
    "thermalZoneId": {
      "type": "string",
      "enum": [
        "PCB",
        "POWER_ZONE_A",
        "POWER_ZONE_B"
      ]
    },
    "totalCurrentTelemetry": {
      "type": "object",
      "required": [
        "shunt_microohm",
        "monitor_range_uv",
        "zero_offset_ma",
        "gain_ppm",
        "stale_timeout_ms",
        "plausible_max_ma"
      ],
      "additionalProperties": false,
      "properties": {
        "shunt_microohm": {
          "type": "integer",
          "minimum": 1
        },
        "monitor_range_uv": {
          "type": "integer",
          "minimum": 1
        },
        "zero_offset_ma": {
          "type": "integer"
        },
        "gain_ppm": {
          "type": "integer",
          "minimum": 1
        },
        "stale_timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "plausible_max_ma": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "thermalTelemetry": {
      "type": "object",
      "required": [
        "id",
        "ntc_nominal_ohm",
        "ntc_beta_k",
        "pullup_ohm",
        "adc_series_ohm",
        "filter_nf",
        "stale_timeout_ms",
        "plausible_min_c",
        "plausible_max_c"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/thermalZoneId"
        },
        "ntc_nominal_ohm": {
          "type": "integer",
          "minimum": 1
        },
        "ntc_beta_k": {
          "type": "integer",
          "minimum": 1
        },
        "pullup_ohm": {
          "type": "integer",
          "minimum": 1
        },
        "adc_series_ohm": {
          "type": "integer",
          "minimum": 1
        },
        "filter_nf": {
          "type": "integer",
          "minimum": 1
        },
        "stale_timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "plausible_min_c": {
          "type": "integer"
        },
        "plausible_max_c": {
          "type": "integer"
        }
      }
    },
    "outputCurrentTelemetry": {
      "type": "object",
      "required": [
        "id",
        "range_ma",
        "zero_offset_ma",
        "gain_ppm",
        "stale_timeout_ms",
        "plausible_max_ma"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/outputId"
        },
        "range_ma": {
          "type": "integer",
          "minimum": 1
        },
        "zero_offset_ma": {
          "type": "integer"
        },
        "gain_ppm": {
          "type": "integer",
          "minimum": 1
        },
        "stale_timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "plausible_max_ma": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rule": {
      "type": "object",
      "required": [
        "name",
        "if",
        "then"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "if": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(engine_running|high_beam|left_indicator|ambient_day|ambient_dusk|ambient_night) == (true|false)$"
          }
        },
        "then": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(USB|CIGARETTE_SOCKET|FOG_LEFT|FOG_RIGHT|CHIGEE|HEATED_SEAT_RIDER|HEATED_SEAT_PASSENGER|DVR|AUX_BRAKE|SPARE|CIGARETTE_COMPRESSOR|HIGH_CURRENT_RESERVE|FOG_PRIMARY_LEFT|FOG_PRIMARY_RIGHT|LOW_CURRENT_RESERVE_1|FOG_SECONDARY_LEFT|FOG_SECONDARY_RIGHT|LOW_CURRENT_RESERVE_2|LOW_CURRENT_RESERVE_3|MEDIUM_CURRENT_RESERVE)\\.pwm = (100|[1-9]?[0-9])$"
          }
        }
      }
    }
  }
}
